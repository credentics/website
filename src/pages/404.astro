---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Not found" description="This page doesn't exist.">
  <main id="main-content" class="relative -mt-20 overflow-hidden pt-20 sm:-mt-24 sm:pt-24">
    <div class="grid-texture"></div>
    <div class="blob -top-32 left-[-10%] h-[380px] w-[65%] rotate-[-8deg] bg-[var(--color-pink)]"></div>
    <div class="blob -top-24 right-[-15%] h-[340px] w-[60%] rotate-[10deg] bg-[var(--color-blue)]"></div>
    <div class="relative mx-auto max-w-2xl px-6 pt-24 pb-28 text-center">
      <h1 class="font-heading text-6xl font-bold tracking-tighter text-[var(--color-ink)] sm:text-7xl">404</h1>
      <p class="mx-auto mt-4 max-w-md text-base leading-relaxed text-[var(--color-muted)]">
        This route doesn't exist — we checked its RBAC just in case.
      </p>

      <a
        href="/"
        class="mt-9 inline-flex items-center gap-2 rounded-full bg-[var(--color-accent)] px-7 py-3 text-sm font-medium text-white transition-transform hover:scale-[1.03]"
      >
        ← Back home
      </a>
    </div>
  </main>
</Layout>
