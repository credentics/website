---
import Layout from '../layouts/Layout.astro';
import MeshGraphic from '../components/MeshGraphic.astro';
import WorkshopGraphic from '../components/WorkshopGraphic.astro';
import BranchGraphic from '../components/BranchGraphic.astro';
import NotesGraphic from '../components/NotesGraphic.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<Layout title="Cloud-native security & identity">
  <main id="main-content">
    <!-- Hero -->
    <section class="relative -mt-20 overflow-hidden pt-20 sm:-mt-24 sm:pt-24">
      <div class="grid-texture"></div>
      <div class="blob -top-32 left-[-10%] h-[420px] w-[70%] rotate-[-8deg] bg-[var(--color-blue)]"></div>
      <div class="blob -top-24 right-[-15%] h-[380px] w-[65%] rotate-[10deg] bg-[var(--color-pink)]"></div>
      <div class="relative mx-auto max-w-5xl px-6 pt-24 pb-28 text-center">
        <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-3.5 py-1 font-mono text-xs text-[var(--color-muted)]">
          <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent)]"></span>
          Open source · Pre-launch
        </span>
        <h1 class="mx-auto mt-7 max-w-3xl font-heading text-6xl font-bold leading-[1.05] tracking-tighter text-[var(--color-ink)] sm:text-7xl lg:text-8xl">
          Secrets shouldn't<br />outlive their
          <em class="relative inline-block not-italic">
            usefulness.
            <svg viewBox="0 0 300 20" preserveAspectRatio="none" aria-hidden="true" class="absolute -bottom-2 left-0 h-3 w-full">
              <path d="M2 14C60 4 240 4 298 14" stroke="url(#squiggle)" stroke-width="5" stroke-linecap="round" fill="none" />
              <defs>
                <linearGradient id="squiggle" x1="0" y1="0" x2="1" y2="0">
                  <stop offset="0%" stop-color="var(--color-pink)" />
                  <stop offset="100%" stop-color="var(--color-accent)" />
                </linearGradient>
              </defs>
            </svg>
          </em>
        </h1>
        <p class="mx-auto mt-7 max-w-xl text-base leading-relaxed text-[var(--color-muted)] sm:text-lg">
          Credentics builds open-source identity infra for the cloud-native world —
          OIDC-native, Kubernetes-shaped, and allergic to long-lived secrets sitting
          around waiting to leak.
        </p>
        <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
          <a
            href="mailto:hello@credentics.io"
            class="group relative rounded-full bg-[var(--color-accent)] px-7 py-3 text-sm font-medium text-white transition-transform hover:scale-[1.03]"
          >
            <span class="absolute inset-x-3 -bottom-1.5 -z-10 h-full rounded-full bg-[var(--color-accent)]/40 blur-md transition-opacity group-hover:opacity-70"></span>
            Talk to us
          </a>
        </div>
        <MeshGraphic class="mx-auto mt-12 h-auto w-full max-w-3xl" />
      </div>
    </section>

    <!-- What we do -->
    <section id="what-we-do" class="relative mx-auto max-w-5xl overflow-hidden px-6 py-20">
      <h2 class="font-mono text-sm font-medium uppercase tracking-wider text-[var(--color-accent)]">What we do</h2>
      <p class="mt-3 max-w-xl font-heading text-3xl font-bold tracking-tight text-[var(--color-ink)]">
        Three ways we help teams get identity right.
      </p>
      <div class="mt-10 grid gap-8 sm:grid-cols-3">
        <a href="#workshops" class="group block">
          <p class="font-mono text-xs text-[var(--color-accent)]">01</p>
          <h3 class="mt-2 font-medium text-[var(--color-ink)] group-hover:text-[var(--color-accent)]">Workshops &amp; training</h3>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
            Hands-on sessions on OIDC, zero trust, and Kubernetes hardening — scoped to your actual stack, not a generic deck.
          </p>
        </a>
        <a href="/workshops#adoption-support" class="group block">
          <p class="font-mono text-xs text-[var(--color-accent)]">02</p>
          <h3 class="mt-2 font-medium text-[var(--color-ink)] group-hover:text-[var(--color-accent)]">Adoption &amp; support</h3>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
            We help take a tool from proof-of-concept to production, then stay on so a broken upgrade doesn't become your problem alone.
          </p>
        </a>
        <a href="#open-source" class="group block">
          <p class="font-mono text-xs text-[var(--color-accent)]">03</p>
          <h3 class="mt-2 font-medium text-[var(--color-ink)] group-hover:text-[var(--color-accent)]">Open-source tooling</h3>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">
            Cloud-native, OIDC-native identity tooling for Kubernetes — open source from the first commit, no asterisk.
          </p>
        </a>
      </div>
    </section>

    <!-- Workshops -->
    <section id="workshops" class="border-t border-[var(--color-border)]">
      <div class="mx-auto max-w-5xl px-6 py-20">
        <div class="grid gap-10 sm:grid-cols-2 sm:items-center">
          <div>
            <div class="flex items-start justify-between gap-6">
              <h2 class="font-mono text-sm font-medium uppercase tracking-wider text-[var(--color-accent)]">Workshops &amp; training</h2>
              <WorkshopGraphic class="hidden h-20 w-20 shrink-0 sm:block" />
            </div>
            <p class="mt-3 font-heading text-3xl font-bold tracking-tight text-[var(--color-ink)]">
              Hands-on sessions, not another slide deck.
            </p>
            <p class="mt-4 text-sm leading-relaxed text-[var(--color-muted)]">
              We run practical workshops for engineering and platform teams —
              OIDC fundamentals, zero trust patterns, and Kubernetes hardening —
              scoped to your actual stack. Remote or on-site.
            </p>
            <div class="mt-6 flex flex-wrap gap-3">
              <a
                href="/workshops"
                class="rounded-full bg-[var(--color-accent)] px-5 py-2.5 text-sm font-medium text-white transition-opacity hover:opacity-90"
              >
                See all workshops
              </a>
              <a
                href="mailto:hello@credentics.io?subject=Workshop%20inquiry"
                class="rounded-full border border-[var(--color-border)] px-5 py-2.5 text-sm font-medium text-[var(--color-ink)] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
              >
                Book a session
              </a>
            </div>
          </div>
          <div class="flex flex-wrap content-start gap-3">
            <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-2 font-mono text-xs text-[var(--color-muted)]">
              <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent)]"></span>
              Half-day or full-day
            </span>
            <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-2 font-mono text-xs text-[var(--color-muted)]">
              <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent)]"></span>
              Remote or on-site
            </span>
            <span class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-2 font-mono text-xs text-[var(--color-muted)]">
              <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent)]"></span>
              Small groups, hands-on labs
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- Open source -->
    <section id="open-source" class="border-t border-[var(--color-border)] bg-[var(--color-surface-2)]/50">
      <div class="mx-auto max-w-5xl px-6 py-20">
        <div class="grid gap-12 sm:grid-cols-2 sm:items-center">
          <div>
            <div class="flex items-start justify-between gap-6">
              <h2 class="font-mono text-sm font-medium uppercase tracking-wider text-[var(--color-accent)]">Open source, by default</h2>
              <BranchGraphic class="hidden h-20 w-20 shrink-0 sm:block" />
            </div>
            <p class="mt-3 font-heading text-3xl font-bold tracking-tight text-[var(--color-ink)]">
              We're new. Everything we ship will be open source.
            </p>
            <p class="mt-4 text-sm leading-relaxed text-[var(--color-muted)]">
              We don't think identity and security infrastructure should be a black box.
              We're a new studio and don't have a public tool out yet — but every
              project we ship will be open source from its first commit, so you can
              audit it, run it yourself, and contribute back instead of taking it on
              faith.
            </p>
          </div>
          <div class="rounded-xl border border-[#212b38] bg-[#0a0e14] p-6 font-mono text-sm shadow-lg">
            <div class="flex gap-1.5">
              <span class="h-2.5 w-2.5 rounded-full bg-[#ef4444]/70"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#f59e0b]/70"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-[#2dd4a7]/70"></span>
            </div>
            <pre class="mt-4 whitespace-pre-wrap text-[#8b96a5]"><span class="text-[#2dd4a7]">$</span> credentics status
status:  pre-launch
license: Apache-2.0 (planned)
first release: in progress</pre>
            <div class="mt-4 flex flex-wrap items-center gap-2 border-t border-[#212b38] pt-4 text-[#8b96a5]">
              <span class="text-[#2dd4a7]">$</span>
              <span>credentics roadmap --watch</span>
              <span class="ml-auto inline-flex items-center gap-1.5 rounded-full border border-[#212b38] px-2.5 py-1 text-[10px] uppercase tracking-wider text-[#2dd4a7]">
                <span class="h-1.5 w-1.5 rounded-full bg-[#2dd4a7] shadow-[0_0_8px_#2dd4a7]"></span>
                live
              </span>
            </div>
            <pre class="mt-3 whitespace-pre-wrap text-xs leading-relaxed text-[#586474]">stream: public changelog
next: first repository
access: open by default</pre>
          </div>
        </div>
      </div>
    </section>

    <!-- Blog teaser -->
    {posts.length > 0 && (
      <section class="mx-auto max-w-5xl px-6 py-20">
        <div class="flex items-end justify-between">
          <div class="flex items-center gap-4">
            <NotesGraphic class="hidden h-14 w-14 shrink-0 sm:block" />
            <h2 class="font-mono text-sm font-medium uppercase tracking-wider text-[var(--color-accent)]">From the blog</h2>
          </div>
          <a href="/blog" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-accent)]">View all →</a>
        </div>
        <div class="mt-8 grid gap-5 sm:grid-cols-3">
          {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="group rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] p-6 transition-colors hover:border-[var(--color-accent-dim)]">
              <p class="font-mono text-xs text-[var(--color-muted)]">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
              </p>
              <h3 class="mt-2 font-medium text-[var(--color-ink)] group-hover:text-[var(--color-accent)]">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</Layout>
