---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Blog" description="Notes on cloud-native security, identity, and OIDC from the Credentics team.">
  <main id="main-content" class="mx-auto max-w-3xl px-6 py-20">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="font-heading text-5xl font-bold tracking-tighter text-[var(--color-ink)]">Blog</h1>
        <p class="mt-3 text-[var(--color-muted)]">
          Notes on cloud-native security, identity, and building in the open.
        </p>
      </div>
      <a
        href="/rss.xml"
        class="mt-2 inline-flex shrink-0 items-center gap-1.5 rounded-full border border-[var(--color-border)] px-3 py-1.5 font-mono text-xs text-[var(--color-muted)] transition-colors hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
      >
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none"><path d="M4 4a16 16 0 0 1 16 16M4 11a9 9 0 0 1 9 9" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><circle cx="5" cy="19" r="1.6" fill="currentColor"/></svg>
        RSS
      </a>
    </div>

    <div class="mt-12 divide-y divide-[var(--color-border)]">
      {posts.map((post) => (
        <a href={`/blog/${post.id}`} class="group block py-7 first:pt-0">
          <p class="font-mono text-xs text-[var(--color-muted)]">
            {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            {' · '}{post.data.author}
          </p>
          <h2 class="mt-2 font-heading text-lg font-bold text-[var(--color-ink)] group-hover:text-[var(--color-accent)]">
            {post.data.title}
          </h2>
          <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">{post.data.description}</p>
        </a>
      ))}
      {posts.length === 0 && (
        <p class="py-10 text-sm text-[var(--color-muted)]">No posts yet — check back soon.</p>
      )}
    </div>
  </main>
</Layout>
