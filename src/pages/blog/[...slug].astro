---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={post.data.title} description={post.data.description}>
  <main id="main-content" class="mx-auto max-w-3xl px-6 py-20">
    <a href="/blog" class="text-sm text-[var(--color-muted)] hover:text-[var(--color-accent)]">← Back to blog</a>
    <h1 class="mt-6 font-heading text-4xl font-bold tracking-tighter text-[var(--color-ink)]">{post.data.title}</h1>
    <p class="mt-3 font-mono text-sm text-[var(--color-muted)]">
      {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
      {' · '}{post.data.author}
    </p>
    <div class="prose-post mt-10">
      <Content />
    </div>
  </main>
</Layout>
