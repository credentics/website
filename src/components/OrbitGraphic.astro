---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg
  viewBox="0 0 960 320"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
  data-draw
>
  <defs>
    <linearGradient id="og-ring" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="var(--color-accent)" />
      <stop offset="100%" stop-color="var(--color-pink)" />
    </linearGradient>
    <linearGradient id="og-key" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="var(--color-blue)" />
      <stop offset="100%" stop-color="var(--color-accent)" />
    </linearGradient>
  </defs>

  <ellipse cx="480" cy="160" rx="330" ry="90" stroke="url(#og-ring)" stroke-width="1.5" stroke-opacity="0.35" class="orbit-ring orbit-ring--slow" />
  <ellipse cx="480" cy="160" rx="230" ry="150" stroke="url(#og-ring)" stroke-width="1.5" stroke-opacity="0.5" class="orbit-ring orbit-ring--reverse" />
  <ellipse cx="480" cy="160" rx="130" ry="200" stroke="var(--color-teal)" stroke-width="1.5" stroke-opacity="0.35" class="orbit-ring orbit-ring--fast" />

  <g transform="translate(480 160)">
    <circle r="34" fill="url(#og-key)" fill-opacity="0.12" />
    <circle cx="-6" cy="-2" r="11" stroke="url(#og-key)" stroke-width="3" class="draw-path" />
    <path d="M2 6l20 20M14 18l7-7M20 24l6-6" stroke="url(#og-key)" stroke-width="3" stroke-linecap="round" class="draw-path" style="transition-delay: 0.3s" />
  </g>

  <circle cx="150" cy="150" r="6" fill="var(--color-yellow)" class="graphic-node" style="animation-delay: 0s" />
  <circle cx="810" cy="140" r="6" fill="var(--color-pink)" class="graphic-node" style="animation-delay: 0.4s" />
  <circle cx="230" cy="250" r="5" fill="var(--color-accent)" class="graphic-node" style="animation-delay: 0.8s" />
  <circle cx="720" cy="250" r="5" fill="var(--color-teal)" class="graphic-node" style="animation-delay: 1.2s" />
  <circle cx="700" cy="60" r="5" fill="var(--color-blue)" class="graphic-node" style="animation-delay: 1.6s" />
  <circle cx="260" cy="60" r="4" fill="var(--color-accent)" class="graphic-node" style="animation-delay: 2s" />
</svg>
