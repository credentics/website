---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg viewBox="0 0 200 160" fill="none" xmlns="http://www.w3.org/2000/svg" class={className} aria-hidden="true" data-draw>
  <defs>
    <linearGradient id="wg-a" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="var(--color-teal)" />
      <stop offset="100%" stop-color="var(--color-accent)" />
    </linearGradient>
  </defs>
  <rect x="16" y="20" width="120" height="82" rx="10" stroke="url(#wg-a)" stroke-width="2" stroke-opacity="0.6" class="draw-path" />
  <path d="M40 46h72M40 62h56M40 78h64" stroke="var(--color-muted)" stroke-width="2" stroke-linecap="round" stroke-opacity="0.35" class="draw-path" style="transition-delay: 0.4s" />
  <rect x="72" y="86" width="96" height="60" rx="10" fill="var(--color-surface)" stroke="url(#wg-a)" stroke-width="2" class="draw-path" style="transition-delay: 0.2s" />
  <circle cx="92" cy="106" r="5" fill="var(--color-pink)" class="graphic-node" style="animation-delay: 0s" />
  <path d="M108 102h44M108 116h30" stroke="var(--color-ink)" stroke-width="2" stroke-linecap="round" stroke-opacity="0.55" class="draw-path" style="transition-delay: 0.6s" />
  <circle cx="150" cy="132" r="5" fill="var(--color-yellow)" class="graphic-node" style="animation-delay: 0.6s" />
</svg>
