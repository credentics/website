---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<a href="/" class={`flex items-center gap-2.5 group ${className}`}>
  <img
    src="/brand-icon.png"
    width="28"
    height="28"
    alt=""
    aria-hidden="true"
    class="h-7 w-7 transition-transform duration-300 group-hover:scale-105"
  />
  <span class="font-semibold tracking-tight text-[var(--color-ink)]">credentics</span>
</a>
