---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<a href="/" class={`flex items-center gap-2.5 group ${className}`}>
  <svg width="26" height="26" viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
    <path
      d="M13 1.5L23.5 6V12.5C23.5 18.7 19.2 23.4 13 24.9C6.8 23.4 2.5 18.7 2.5 12.5V6L13 1.5Z"
      stroke="var(--color-accent)"
      stroke-width="1.6"
      stroke-linejoin="round"
      class="transition-transform duration-300 group-hover:scale-105"
    ></path>
    <path
      d="M9 13L11.8 15.8L17.2 10"
      stroke="var(--color-accent)"
      stroke-width="1.6"
      stroke-linecap="round"
      stroke-linejoin="round"
    ></path>
  </svg>
  <span class="font-semibold tracking-tight text-[var(--color-ink)]">credentics</span>
</a>
