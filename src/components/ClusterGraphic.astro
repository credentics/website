---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---

<svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class={className} aria-hidden="true" data-draw>
  <defs>
    <linearGradient id="cg-a" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="var(--color-accent)" />
      <stop offset="100%" stop-color="var(--color-blue)" />
    </linearGradient>
  </defs>
  <path d="M100 20 165 57.5V132.5L100 170 35 132.5V57.5Z" stroke="url(#cg-a)" stroke-width="2" stroke-opacity="0.5" class="draw-path" />
  <path d="M100 55 132 73.5V110.5L100 129 68 110.5V73.5Z" stroke="var(--color-teal)" stroke-width="2" stroke-opacity="0.7" class="draw-path" style="transition-delay: 0.3s" />
  <circle cx="100" cy="20" r="4" fill="var(--color-accent)" class="graphic-node" style="animation-delay: 0s" />
  <circle cx="165" cy="57.5" r="4" fill="var(--color-pink)" class="graphic-node" style="animation-delay: 0.3s" />
  <circle cx="165" cy="132.5" r="4" fill="var(--color-yellow)" class="graphic-node" style="animation-delay: 0.6s" />
  <circle cx="100" cy="170" r="4" fill="var(--color-accent)" class="graphic-node" style="animation-delay: 0.9s" />
  <circle cx="35" cy="132.5" r="4" fill="var(--color-blue)" class="graphic-node" style="animation-delay: 1.2s" />
  <circle cx="35" cy="57.5" r="4" fill="var(--color-teal)" class="graphic-node" style="animation-delay: 1.5s" />
</svg>
